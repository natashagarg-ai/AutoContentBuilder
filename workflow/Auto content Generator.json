        },
        "messages": {
          "values": [
            {
              "content": "=You are @AutoContentGen. Generate content for ONE specific AI/tech development.\n\nBANNED TOPICS: {{$json.bannedList}}\n\nOUTPUT AS VALID JSON ONLY - NO MARKDOWN, NO EXPLANATION:\n\n{\n  \"topic\": \"3-5 words\",\n  \"tweet1\": \"hook under 100 chars\",\n  \"tweet2\": \"insight under 200 chars\",\n  \"tweet3\": \"insight under 200 chars\",\n  \"tweet4\": \"insight under 200 chars\",\n  \"tweet5\": \"CTA under 150 chars\",\n  \"linkedin\": \"professional post 400-600 chars\",\n  \"instagram\": \"casual caption under 300 chars\",\n  \"hashtags\": \"3-5 hashtags\",\n  \"imagePrompt\": \"detailed image prompt 60-100 words\"\n}\n\nRULES:\n- Output ONLY the JSON object\n- No code blocks, no backticks\n- Real numbers, names, dates\n- Senior engineer tone\n- NO generic phrases\n\nCurrent date: July 15, 2026. Pick from June 20 - July 15, 2026."
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "systemMessage": "You write sharp, opinionated tech content. Every word earns its place. No filler."
        }
      },
