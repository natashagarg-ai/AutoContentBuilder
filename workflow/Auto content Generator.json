    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);\nconst recentTopics = items\n  .map(item => ({\n    date: new Date(item.json.Date || item.json.date || '2026-01-01'),\n    topic: item.json.Topic || item.json.topic || ''\n  }))\n  .filter(item => item.date >= sevenDaysAgo && item.topic.length > 3)\n  .map(item => item.topic.substring(0, 100));\nconst bannedTopics = [...new Set(recentTopics)].slice(0, 15);\nreturn [{\n  json: {\n    bannedTopics: bannedTopics,\n    bannedCount: bannedTopics.length,\n    bannedList: bannedTopics.join(' | ') || 'NONE_YET'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
