    {
      "parameters": {
        "jsCode": "const text = $json.content?.parts?.[0]?.text || $json.text || '';\n\n// Extract JSON from response (remove any markdown code blocks if present)\nconst jsonMatch = text.match(/\\{[\\s\\S]*\\}/);\nconst jsonStr = jsonMatch ? jsonMatch[0] : text;\n\nlet data;\ntry {\n  data = JSON.parse(jsonStr);\n} catch (e) {\n  // Fallback if JSON parsing fails\n  return [{\n    json: {\n      topic: 'Parse Error',\n      tweet1: text.slice(0, 280),\n      tweet2: '',\n      tweet3: '',\n      tweet4: '',\n      tweet5: '',\n      twitterThread: text,\n      linkedin: '',\n      instagram: '',\n      hashtags: '',\n      imagePrompt: '',\n      rawText: text\n    }\n  }];\n}\n\nconst tweets = [data.tweet1, data.tweet2, data.tweet3, data.tweet4, data.tweet5].filter(t => t);\n\nreturn [{\n  json: {\n    topic: data.topic || '',\n    tweet1: data.tweet1 || '',\n    tweet2: data.tweet2 || '',\n    tweet3: data.tweet3 || '',\n    tweet4: data.tweet4 || '',\n    tweet5: data.tweet5 || '',\n    twitterThread: tweets.join('\\n\\n'),\n    linkedin: data.linkedin || '',\n    instagram: data.instagram || '',\n    hashtags: data.hashtags || '',\n    imagePrompt: data.imagePrompt || data.image_prompt || '',\n    rawText: text\n  }\n}];"
      },
